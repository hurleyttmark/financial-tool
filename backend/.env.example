# Required: Your Alpha Vantage API key (https://www.alphavantage.co/support/#api-key)
ALPHA_VANTAGE_API_KEY=your_key_here

# Optional: Set to "yfinance" to use yfinance as zero-key local fallback (default: alphavantage)
DATA_SOURCE=alphavantage

# Optional: SQLite database path (default: ./cache.db)
DB_PATH=./cache.db

# Optional: Log file path (default: ./app.log)
LOG_PATH=./app.log
